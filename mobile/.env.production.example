# IAMS Mobile App - PRODUCTION Environment Configuration
# Copy this file to .env.production and update values for your deployment

# ===== Backend API Configuration =====
# Development (laptop on local network)
# API_BASE_URL=http://192.168.1.100:8000/api/v1
# WS_BASE_URL=ws://192.168.1.100:8000/api/v1/ws

# Production (cloud deployment with HTTPS)
# API_BASE_URL=https://api.yourdomain.com/api/v1
# WS_BASE_URL=wss://api.yourdomain.com/api/v1/ws

# Pilot Testing (laptop on same WiFi - update IP address)
API_BASE_URL=http://192.168.1.100:8000/api/v1
WS_BASE_URL=ws://192.168.1.100:8000/api/v1/ws

# ===== Supabase Configuration =====
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ===== App Configuration =====
APP_NAME=IAMS
APP_VERSION=1.0.0
ENVIRONMENT=production

# ===== Feature Flags =====
ENABLE_FACE_REGISTRATION=true
ENABLE_WEBSOCKET_UPDATES=true
ENABLE_PUSH_NOTIFICATIONS=false  # Not implemented in MVP

# ===== Network Configuration =====
API_TIMEOUT=30000  # milliseconds
WEBSOCKET_RECONNECT_INTERVAL=5000  # milliseconds
MAX_RETRY_ATTEMPTS=3

# ===== Mobile App Deployment Notes =====
#
# For Expo Development Build:
# 1. Update this file with correct API_BASE_URL
# 2. Build: npx expo prebuild
# 3. Android: npx expo run:android
# 4. iOS: npx expo run:ios
#
# For Standalone Builds:
# 1. Install EAS CLI: npm install -g eas-cli
# 2. Login: eas login
# 3. Configure: eas build:configure
# 4. Build Android: eas build --platform android
# 5. Build iOS: eas build --platform ios
#
# For APK Distribution (Pilot Testing):
# 1. Build APK: eas build -p android --profile preview
# 2. Download APK from Expo dashboard
# 3. Distribute via USB, email, or file sharing
# 4. Install on Android devices (enable "Install from unknown sources")
#
# For TestFlight (iOS):
# 1. Build: eas build -p ios --profile production
# 2. Submit to TestFlight: eas submit -p ios
# 3. Invite testers via App Store Connect
#
# Network Configuration for Pilot Testing:
# 1. Ensure backend is running and accessible
# 2. Find backend IP: ipconfig (Windows) or ifconfig (Linux/Mac)
# 3. Update API_BASE_URL with backend IP
# 4. Test connectivity: ping <backend-ip>
# 5. Ensure all devices are on same WiFi network
