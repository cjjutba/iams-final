{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "API_BASE_URL": "http://167.71.217.44/api/v1",
        "WS_BASE_URL": "ws://167.71.217.44/api/v1/ws"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "API_BASE_URL": "http://167.71.217.44/api/v1",
        "WS_BASE_URL": "ws://167.71.217.44/api/v1/ws"
      }
    },
    "pilot": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "API_BASE_URL": "http://167.71.217.44/api/v1",
        "WS_BASE_URL": "ws://167.71.217.44/api/v1/ws"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "API_BASE_URL": "http://167.71.217.44/api/v1",
        "WS_BASE_URL": "ws://167.71.217.44/api/v1/ws"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./android-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "1234567890",
        "appleTeamId": "ABCDEFGH12"
      }
    }
  }
}
