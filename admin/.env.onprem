# Admin portal — ONPREM build environment.
# Vite loads this when the admin-build sidecar runs with `--mode onprem`.
#
# All URLs are relative because the built admin is served by the same nginx
# that proxies /api, /api/v1/ws, and /whep on the local Mac.

VITE_API_URL=/api/v1

# Empty — the use-websocket.ts hook falls back to window.location.host
# (wss:// on HTTPS, ws:// on HTTP) when this is unset.
VITE_WS_URL=

# WHEP endpoint for the admin portal's live-feed page. Proxied by nginx
# to the local mediamtx container at port 8889.
VITE_STREAM_WEBRTC_URL=/whep

# Supabase — used by the email-confirmation + password-reset pages. The
# anon key is a public client-side credential by design.
VITE_SUPABASE_URL=https://fspnxqmewtxmuyqqwwni.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZzcG54cW1ld3R4bXV5cXF3d25pIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA0NDgyMjQsImV4cCI6MjA4NjAyNDIyNH0.HKzVotT7jpoRCA7ENJHMRhd6rE5hTzfxAL5ou5dp9ls
