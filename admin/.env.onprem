# Admin portal — ONPREM build environment.
# Vite loads this when the admin-build sidecar runs with `--mode onprem`.
#
# All URLs are relative because the built admin is served by the same nginx
# that proxies /api, /api/v1/ws, and /whep on the local Mac.

VITE_API_URL=/api/v1

# Empty — the use-websocket.ts hook falls back to window.location.host
# (wss:// on HTTPS, ws:// on HTTP) when this is unset.
VITE_WS_URL=

# WHEP endpoint for the admin portal's live-feed page. Proxied by nginx
# to the local mediamtx container at port 8889.
VITE_STREAM_WEBRTC_URL=/whep

# RTP-PTS frame aligner (live-feed plan 2026-04-25 Step 3c).
# When `1`, the live overlay pins each WS bbox draw to the matching WHEP
# video frame using `requestVideoFrameCallback().rtpTimestamp` ↔ backend's
# `rtp_pts_90k`. Eliminates the "box lags behind moving face" effect the
# 524 ms WS-to-video latency creates at backend FPS ≤ 5. Set to `0` to
# fall back to the latest-frame-only behavior (still post-Step-1 honest
# blink, just without RTP alignment).
VITE_ENABLE_FRAME_ALIGN=1

# Fixed display delay (ms) added to the bbox overlay path. Compensates
# for the latency gap between admin SUB-stream video (~300 ms WHEP +
# jitter) and the WS overlay path (~150-200 ms ML+broadcast post-fps-
# bump on 2026-04-25). Without this, the bbox visibly leads the video
# because backend overlay is faster than the WHEP video pipeline. The
# delay is purely additive on the overlay; total page latency stays at
# the existing video latency. Set to 0 if/when admin and ML pipelines
# share a publisher clock (e.g. after a separate `-display` fanout path
# is provisioned, which would also let the PTS aligner above do real
# frame-accurate matching). See use-frame-aligner.ts for the mechanics.
# 2026-04-25 evening: temporarily set to 0 for an A/B test of the no-delay
# experience. Flip to 100 to re-enable the delay-based sync.
VITE_OVERLAY_DISPLAY_DELAY_MS=0

# Supabase — used by the email-confirmation + password-reset pages. The
# anon key is a public client-side credential by design.
VITE_SUPABASE_URL=https://fspnxqmewtxmuyqqwwni.supabase.co
