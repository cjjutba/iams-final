# Admin portal — PRODUCTION build environment.
# Copy this file to admin/.env.production on first clone; values below are
# the canonical VPS URLs and do not need to be customised per-machine.
#
# Vite loads this file for `npm run build` (production mode). The committed
# Vercel deployment of the admin portal reads it at build time.

VITE_API_URL=/api/v1
VITE_WS_URL=ws://167.71.217.44

# Admin-portal live-feed WebRTC WHEP endpoint (onprem mode only).
# Relative path, proxied by local nginx to the Mac's mediamtx in onprem mode,
# or by Vite's /whep proxy in dev. Empty/ignored in production (Vercel).
VITE_STREAM_WEBRTC_URL=/whep

# Supabase (used by the email-verification + password-reset pages).
# The anon key is a public client-side credential by design — safe to commit.
VITE_SUPABASE_URL=https://fspnxqmewtxmuyqqwwni.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZzcG54cW1ld3R4bXV5cXF3d25pIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA0NDgyMjQsImV4cCI6MjA4NjAyNDIyNH0.HKzVotT7jpoRCA7ENJHMRhd6rE5hTzfxAL5ou5dp9ls
