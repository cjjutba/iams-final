# Admin portal — LOCAL DEV environment.
# Copy this file to admin/.env on first clone and fill in <YOUR_LAN_IP>.
# The "switch to local" protocol in CLAUDE.md writes this file automatically.
#
# Vite loads this file for `npm run dev`. For production builds
# (`npm run build`) Vite reads admin/.env.production instead.

VITE_API_URL=http://<YOUR_LAN_IP>:8000/api/v1
VITE_WS_URL=ws://<YOUR_LAN_IP>:8000

# Supabase (used by the email-verification + password-reset pages).
# The anon key is a public client-side credential by design — safe to commit.
