# IAMS Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Application
APP_NAME=IAMS
DEBUG=true
API_PREFIX=/api/v1

# Database Connection (local Docker PostgreSQL)
DATABASE_URL=postgresql://iams:iams_dev_password@postgres:5432/iams

# JWT Settings (for custom faculty authentication)
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated list)
# In production, specify exact origins like: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=["*"]

# Face Recognition Settings
FAISS_INDEX_PATH=data/faiss/faces.index
RECOGNITION_THRESHOLD=0.6
USE_GPU=true
FACE_IMAGE_SIZE=160
MIN_FACE_IMAGES=3
MAX_FACE_IMAGES=5

# Redis
REDIS_URL=redis://localhost:6379/0

# Presence Tracking Settings
SCAN_INTERVAL_SECONDS=60
EARLY_LEAVE_THRESHOLD=3
GRACE_PERIOD_MINUTES=15
SESSION_BUFFER_MINUTES=5

# File Storage
UPLOAD_DIR=data/uploads/faces
MAX_UPLOAD_SIZE_MB=10

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=IAMS <noreply@iams.jrmsu.edu.ph>
EMAIL_ENABLED=false

# Notification Jobs
DAILY_DIGEST_HOUR=18
WEEKLY_DIGEST_HOUR=19
NOTIFICATION_RETENTION_DAYS=90
LOW_ATTENDANCE_CHECK_WINDOW_DAYS=30
LOW_ATTENDANCE_RENOTIFY_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
