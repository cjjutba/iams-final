# IAMS Backend - PRODUCTION Environment Configuration
# Copy this file to .env.production and fill in your actual values
# CRITICAL: Never commit this file with real secrets to version control

# ===== Application =====
APP_NAME=IAMS
DEBUG=false  # MUST be false in production
API_PREFIX=/api/v1

# ===== Database Connection (local Docker PostgreSQL) =====
DATABASE_URL=postgresql://iams:iams_dev_password@postgres:5432/iams

# ===== JWT Settings =====
# CRITICAL: Generate a strong random secret key for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_THIS_TO_STRONG_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS Origins =====
# CRITICAL: Specify exact origins in production, NOT wildcard "*"
# Format: ["https://yourdomain.com","https://app.yourdomain.com"]
# For pilot testing on local network: ["http://192.168.1.100:8000"]
CORS_ORIGINS=["https://yourdomain.com"]

# ===== Face Recognition Settings =====
FAISS_INDEX_PATH=data/faiss/faces.index
RECOGNITION_THRESHOLD=0.6
USE_GPU=true  # Set to false if no GPU available
FACE_IMAGE_SIZE=160
MIN_FACE_IMAGES=3
MAX_FACE_IMAGES=5

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0  # In Docker: redis://redis:6379/0

# ===== Presence Tracking Settings =====
SCAN_INTERVAL_SECONDS=60
EARLY_LEAVE_THRESHOLD=3
GRACE_PERIOD_MINUTES=15
SESSION_BUFFER_MINUTES=5

# ===== Real-Time Pipeline tuning =====
# These values are what the VPS actually ran at after the 2026-04-18 A+B
# CPU optimisation. Keep them unless you migrate to a GPU backend.
# Drop PROCESSING_FPS / FRAME_GRABBER_FPS in lockstep — mismatches cause
# FFmpeg "frames duplicated" warnings and mediamtx backpressure.
PROCESSING_FPS=5
FRAME_GRABBER_FPS=5
FRAME_GRABBER_WIDTH=960
FRAME_GRABBER_HEIGHT=540

# InsightFace model + detector size. buffalo_s = MobileFaceNet recognition
# (~4x faster than buffalo_l's ResNet50 on CPU) + SCRFD-500M detection
# (~2x faster than SCRFD-10G). Det size 320 roughly halves SCRFD cost vs 640.
# Combined gain on CPU DigitalOcean: ~4x throughput, minor accuracy cost
# (~5% FAR regression at equivalent FRR on clean enrolled faces).
INSIGHTFACE_MODEL=buffalo_s
INSIGHTFACE_DET_SIZE=320

# SCRFD detection confidence floor. Default 0.3 is permissive and causes
# phantom detections (shadows, partial faces at frame edges) that the
# recognizer then has to label "unknown". Raised to 0.5 on 2026-04-18 —
# eliminates the "ghost Unknown box on empty area" artefact visible in
# the live feed. If distant faces fail to detect, lower incrementally
# (0.45, then 0.4) rather than going back to 0.3.
INSIGHTFACE_DET_THRESH=0.5

# ===== File Storage =====
UPLOAD_DIR=data/uploads/faces
MAX_UPLOAD_SIZE_MB=10

# ===== Logging =====
LOG_LEVEL=INFO  # Use INFO or WARNING in production
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ===== Production Deployment Notes =====
# 1. Generate strong SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. Set DEBUG=false
# 3. Use specific CORS origins (not "*")
# 4. Ensure DATABASE_URL uses pooler connection
# 5. Create logs/ and data/faiss/ directories before starting
# 6. Backup FAISS index regularly
# 7. Monitor LOG_FILE for errors
# 8. Use HTTPS in production (reverse proxy with nginx + Let's Encrypt)
