# IAMS Backend — VPS (thin-profile) Environment
#
# Used by the public-facing VPS (167.71.217.44). After the 2026-04-22 two-app
# split, the VPS runs the SAME backend image as the on-prem Mac but with every
# heavy feature disabled — its only job is:
#
#   1. Authenticate the faculty mobile app (/api/v1/auth/*).
#   2. Serve that faculty's schedules + rooms (/api/v1/schedules/me, /rooms).
#   3. Relay the public WebRTC stream (via sibling mediamtx + coturn
#      containers — NOT this backend).
#
# No face embeddings, no attendance records, no student PII live here.
#
# Copy this file to backend/.env.vps on the VPS:
#   scp backend/.env.vps.example root@167.71.217.44:/opt/iams/backend/.env.vps
#   ssh root@167.71.217.44 "nvim /opt/iams/backend/.env.vps"
# ...then fill in real secrets (SECRET_KEY, POSTGRES_PASSWORD).
#
# CRITICAL: backend/.env.vps is gitignored. Never commit real secrets.

# ===== Application =====
APP_NAME=IAMS
DEBUG=false
API_PREFIX=/api/v1

# ===== Database =====
# docker-compose.vps.yml injects DATABASE_URL with the actual
# POSTGRES_PASSWORD. Value here is a fallback for bare invocations.
DATABASE_URL=postgresql://iams:iams_vps_password@postgres:5432/iams

# ===== JWT Settings =====
# MUST be different from the on-prem Mac's SECRET_KEY — tokens minted by the
# VPS are only valid on the VPS (separate user tables, separate keyspace).
# Generate fresh:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_THIS_TO_STRONG_RANDOM_SECRET_KEY_FOR_VPS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== CORS =====
# The faculty mobile app is the only real client. Add your Android scheme
# origins here if you later enable CORS-checked webviews. Admin portal does
# NOT talk to the VPS — it's served from the on-prem Mac.
CORS_ORIGINS=["http://167.71.217.44","https://167.71.217.44"]

# ===== Feature Flags (2026-04-22 two-app split) =====
# Every heavy feature OFF. The backend still serves: auth, users, schedules,
# rooms, health. Everything else 404s.
ENABLE_ML=false
ENABLE_REDIS=false
ENABLE_FRAME_GRABBERS=false
ENABLE_BACKGROUND_JOBS=false
ENABLE_FACE_ROUTES=false
ENABLE_ATTENDANCE_ROUTES=false
ENABLE_PRESENCE_ROUTES=false
ENABLE_ANALYTICS_ROUTES=false
ENABLE_NOTIFICATION_ROUTES=false
ENABLE_AUDIT_ROUTES=false
ENABLE_EDGE_ROUTES=false
ENABLE_SETTINGS_ROUTES=false
ENABLE_WS_ROUTES=false
ENABLE_RECOGNITION_ROUTES=false
ENABLE_ACTIVITY_ROUTES=false

# Sync receiver: ON. The VPS accepts faculty + schedule + room +
# faculty_record snapshots from the on-prem Mac via POST
# /api/v1/sync/upsert. Auth via X-Sync-Secret header compared against
# VPS_SYNC_SECRET (injected by deploy/docker-compose.vps.yml from the
# environment — see deploy/deploy.sh).
ENABLE_SYNC_RECEIVER_ROUTES=true

# ===== Redis =====
# Not used when ENABLE_REDIS=false, but kept populated so the settings model
# validates. The VPS docker-compose.vps.yml does NOT run a Redis container.
REDIS_URL=redis://redis:6379/0

# ===== Face Recognition =====
# All values here are defaults only — they're never read when ENABLE_ML=false.
# Kept populated so the Settings model validates during startup.
FAISS_INDEX_PATH=data/faiss/faces.index
RECOGNITION_THRESHOLD=0.38
USE_GPU=false

# ===== File Storage =====
# Face uploads are rejected (ENABLE_FACE_ROUTES=false), so this path is
# never written. Kept for Settings model validation.
UPLOAD_DIR=data/uploads/faces
MAX_UPLOAD_SIZE_MB=10

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===== Email =====
# Faculty might trigger password-reset emails. If Resend isn't configured,
# set EMAIL_ENABLED=false — the backend skips sending gracefully.
RESEND_API_KEY=CHANGE_THIS_OR_LEAVE_EMAIL_ENABLED_FALSE
RESEND_FROM_EMAIL=onboarding@resend.dev
EMAIL_ENABLED=false

# ===== Admin URL =====
# Used in password-reset emails only. Point at the faculty app's custom URL
# scheme OR (simpler) at the admin portal on the on-prem Mac — faculty on
# IAMS-Net can reset there.
ADMIN_URL=http://167.71.217.44

# ===== Service role =====
SERVICE_ROLE=api-gateway

# ===== Edge device key =====
# Unused (ENABLE_EDGE_ROUTES=false) but validated by Settings. Any non-default
# value works.
EDGE_API_KEY=iams-vps-edge-key-unused-2026

# ===== VPS First-Boot Checklist =====
# 1. Generate SECRET_KEY (above).
# 2. Set POSTGRES_PASSWORD in /opt/iams/backend/.env.vps AND export it in
#    the shell running `docker compose up` — it's used in both places.
# 3. Deploy: `bash deploy/deploy.sh vps`
# 4. Seed faculty + schedules + rooms:
#      ssh root@167.71.217.44 'docker exec iams-api-gateway-vps python -m scripts.seed_vps_minimal'
# 5. Test faculty login from anywhere with internet:
#      curl -X POST http://167.71.217.44/api/v1/auth/login \
#        -H 'Content-Type: application/json' \
#        -d '{"identifier":"faculty.eb226@gmail.com","password":"password123"}'
