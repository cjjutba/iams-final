# IAMS — Local-only environment overrides.
#
# This file is sourced by scripts/onprem-up.sh and scripts/deploy.sh when
# present. It lives OUTSIDE the repo's tracked .env files because:
#   - It contains a secret (POSTGRES_PASSWORD) that must match the baked-in
#     value of the Docker postgres volume, which differs per machine.
#   - It is per-operator: every developer who brings up the on-prem stack
#     on a fresh Mac picks their own password on first boot, and sticks
#     with it until they wipe the `postgres_data_onprem` volume.
#
# To use:
#   cp scripts/.env.local.example scripts/.env.local
#   $EDITOR scripts/.env.local    # fill POSTGRES_PASSWORD
#
# The actual scripts/.env.local is gitignored.

# The password baked into the iams-postgres-onprem volume on FIRST boot.
# Changing this value after the DB is already initialised requires either:
#   - Wiping the volume: ./scripts/onprem-down.sh --purge
#   - Or doing an in-place `ALTER USER iams WITH PASSWORD '...';` via psql
#     before updating this file.
#
# If you don't remember what you picked the first time, check:
#   docker exec iams-postgres-onprem cat /var/lib/postgresql/data/pg_hba.conf
#   (won't help — but a bad password yields "password authentication failed"
#    from api-gateway; easiest fix is --purge + fresh seed.)
POSTGRES_PASSWORD=CHANGE_ME
