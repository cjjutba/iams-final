# IAMS — Local-only environment overrides.
#
# This file is sourced by scripts/onprem-up.sh and scripts/deploy.sh when
# present. It lives OUTSIDE the repo's tracked .env files because:
#   - It contains a secret (POSTGRES_PASSWORD) that must match the baked-in
#     value of the Docker postgres volume, which differs per machine.
#   - It is per-operator: every developer who brings up the on-prem stack
#     on a fresh Mac picks their own password on first boot, and sticks
#     with it until they wipe the `postgres_data_onprem` volume.
#
# To use:
#   cp scripts/.env.local.example scripts/.env.local
#   $EDITOR scripts/.env.local    # fill POSTGRES_PASSWORD
#
# The actual scripts/.env.local is gitignored.

# The password baked into the iams-postgres-onprem volume on FIRST boot.
# Changing this value after the DB is already initialised requires either:
#   - Wiping the volume: ./scripts/onprem-down.sh --purge
#   - Or doing an in-place `ALTER USER iams WITH PASSWORD '...';` via psql
#     before updating this file.
#
# If you don't remember what you picked the first time, check:
#   docker exec iams-postgres-onprem cat /var/lib/postgresql/data/pg_hba.conf
#   (won't help — but a bad password yields "password authentication failed"
#    from api-gateway; easiest fix is --purge + fresh seed.)
POSTGRES_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────────────────────────────
# Mac → VPS sync secret
#
# The on-prem api-gateway pushes faculty + admin user rows + rooms +
# schedules + faculty_records to the VPS receiver every
# VPS_SYNC_INTERVAL_SECONDS. Both ends compare against this secret in
# the X-Sync-Secret header. Generate fresh:
#
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# This SAME value is used on the VPS — deploy/deploy.sh propagates it
# to the docker compose env at deploy time, so you set it once here and
# never have to copy it manually.
#
# Empty value = sync sender no-ops (safe default for fresh clones).
VPS_SYNC_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Nightly backup encryption passphrase
#
# Used by scripts/iams-backup.sh to encrypt the pg_dump output before
# it ever lands on disk (gpg --symmetric --cipher-algo AES256).
#
# CRITICAL: SAVE THIS IN YOUR PASSWORD MANAGER. Without it, the
# encrypted dumps are unrecoverable. The Mac drive failing AND losing
# this passphrase = no backup, ever. Treat with the same care as a
# disk-encryption passphrase.
#
# Generate fresh:
#   python3 -c "import secrets; print(secrets.token_urlsafe(40))"
#
# Empty value = scripts/iams-backup.sh refuses to run (fail-safe; we
# never want to write *unencrypted* dumps even by accident).
IAMS_BACKUP_GPG_PASSPHRASE=

# Optional overrides — defaults are sensible.
#
# IAMS_BACKUP_DIR=~/iams-backups            # where local dumps land
# IAMS_BACKUP_VPS_HOST=root@167.71.217.44   # off-site copy destination
# IAMS_BACKUP_VPS_DIR=/var/backups/iams     # path on the VPS
# IAMS_BACKUP_RETENTION_DAYS=14             # prune both sides after N days
# IAMS_BACKUP_HOUR=3                        # daily run time, hour (0-23)
# IAMS_BACKUP_MINUTE=0                      # daily run time, minute
