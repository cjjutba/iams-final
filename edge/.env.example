# IAMS Edge Device Configuration
# Copy this file to .env and configure for your environment

# ===== Relay Target (where the RPi pushes RTSP) =====
#
# After the 2026-04-21 local-compute split, set RELAY_HOST to the on-prem Mac's
# static DHCP IP on IAMS-Net (the Mac's mediamtx re-publishes to the VPS
# automatically via runOnReady). Legacy VPS_HOST is still read as a fallback.
#
# Pre-split:  RELAY_HOST=167.71.217.44
# Post-split: RELAY_HOST=192.168.88.xx  (Mac on IAMS-Net)
RELAY_HOST=192.168.88.17

# Legacy alias — set RELAY_HOST above instead. Kept here for the iams-relay-start.sh
# fallback chain so already-deployed .env files keep working.
# VPS_HOST=167.71.217.44

# Deprecated — the old HTTP face-detection pipeline is no longer used.
BACKEND_URL=http://167.71.217.44

# REQUIRED: Room identifier. Becomes the mediamtx path name — e.g. `eb226`.
# Admin portal's camera_endpoint for this room should match: rtsp://mediamtx:8554/{ROOM_ID}.
ROOM_ID=eb226

# ===== Camera Configuration =====
# Camera source: "auto" (try picamera→rtsp→usb), "picamera", "rtsp", "usb"
# Use "rtsp" for IP cameras like Reolink P340
CAMERA_SOURCE=auto

# --- RTSP Settings (for IP cameras like Reolink P340) ---
# Format: rtsp://username:password@IP_ADDRESS/Preview_01_main
# Reolink defaults: username=admin, password=your_camera_password
# Main stream = full 12MP (4512x2512), Sub stream = lower resolution
# Example: RTSP_URL=rtsp://admin:MyPassword123@192.168.1.100/Preview_01_main
RTSP_URL=

# RTSP transport: "tcp" (recommended for PoE) or "udp"
RTSP_TRANSPORT=tcp

# Delay before RTSP reconnection attempt (seconds)
RTSP_RECONNECT_DELAY=5

# --- USB Camera Settings ---
# Camera device index (0 for first camera, 1 for second, etc.)
CAMERA_INDEX=0

# Camera resolution (width x height) — applies to USB/picamera only
# RTSP uses the stream's native resolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Camera frame rate (FPS)
CAMERA_FPS=15

# ===== Face Detection Configuration =====
# Face crop size in pixels (sent to backend)
FACE_CROP_SIZE=112

# JPEG compression quality (1-100, higher = better quality but larger file)
JPEG_QUALITY=70

# MediaPipe detection confidence threshold (0.0-1.0)
DETECTION_CONFIDENCE=0.5

# MediaPipe detection model (0 = short-range, the only model compatible with Tasks API)
# The full-range model (1) is NOT compatible and will cause tensor errors.
# Lower DETECTION_CONFIDENCE (e.g., 0.3-0.4) to detect faces at greater distances.
DETECTION_MODEL=0

# ===== Queue Configuration =====
# Maximum queue size (number of failed requests to queue)
QUEUE_MAX_SIZE=500

# Queue time-to-live in seconds (discard entries older than this)
QUEUE_TTL_SECONDS=300

# Retry interval in seconds (wait time between retry attempts)
RETRY_INTERVAL_SECONDS=10

# Maximum retry attempts per request
RETRY_MAX_ATTEMPTS=3

# ===== Processing Configuration =====
# Scan interval in seconds (time between face detection scans)
# Recommended: 60 seconds for continuous presence tracking
SCAN_INTERVAL=60

# ===== Session Awareness Configuration =====
# When enabled, edge device polls the backend to check for active attendance
# sessions before scanning. Prevents wasted scans when no class is in session.
# Set to "false" to scan unconditionally (original behavior).
SESSION_AWARE=true

# How often to poll for active sessions when no session is running (seconds).
# Uses the shorter poll interval when idle, switches to SCAN_INTERVAL when active.
SESSION_POLL_INTERVAL=10

# ===== Stream Relay Configuration =====
# When enabled, FFmpeg relays the camera RTSP sub-stream to the VPS mediamtx
# for WebRTC live viewing by faculty from any network.
# Requires FFmpeg installed: sudo apt install ffmpeg
STREAM_RELAY_ENABLED=false

# VPS mediamtx RTSP ingest URL (no trailing slash, no path)
# The room ID is appended automatically: rtsp://VPS_IP:8554/{room_id}
# Example: STREAM_RELAY_URL=rtsp://167.71.217.44:8554
STREAM_RELAY_URL=

# Seconds to wait before retrying FFmpeg after it dies
STREAM_RELAY_RETRY_DELAY=5

# ===== HTTP Configuration =====
# HTTP request timeout in seconds
HTTP_TIMEOUT=30

# Maximum HTTP retries before queuing
HTTP_MAX_RETRIES=3

# ===== Logging Configuration =====
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: Log file path (leave empty to log to console only)
# LOG_FILE=/var/log/iams-edge.log
