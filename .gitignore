# Android signing — never commit keystores or APKs.
# The signed APK is built and published by .github/workflows/build-apk.yml
# and lives only in GitHub Releases.
*.jks
*.keystore
keystore.properties
admin/public/iams.apk
admin/public/iams-student.apk
admin/public/iams-faculty.apk
deploy/static/iams.apk
deploy/static/iams-student.apk
deploy/static/iams-faculty.apk

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
*.egg-info/
dist/
build/

# Environment
.env
.env.local
.env.production
*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Database
*.db
*.sqlite3

# FAISS
data/faiss/*.index

# Binaries — downloaded separately, never committed (see scripts/start_mediamtx.sh)
backend/bin/*
!backend/bin/.gitkeep

# HLS segments (generated at runtime)
backend/data/hls/

# MediaPipe models (downloaded at runtime)
edge/app/.models/
edge/tools/.cache/
backend/data/models/

# Logs
*.log
logs/

# Uploads
data/uploads/*
!data/uploads/.gitkeep

# OS
.DS_Store
Thumbs.db
nul

# Testing
.coverage
htmlcov/
.pytest_cache/

# Backups
*.bak
backups/

# Temporary
tmp/
temp/
*.tmp

# mediamtx binary (downloaded locally, not committed)
backend/bin/mediamtx
backend/bin/mediamtx.exe

# mediamtx runtime configs — generated from templates by scripts/onprem-up.sh
# (and scripts/dev-up.sh in the future). Committing these would leak the
# host's LAN IP via webrtcAdditionalHosts.
deploy/mediamtx.*.generated.yml

# Per-machine operator secrets sourced by scripts/onprem-up.sh and
# scripts/deploy.sh — chiefly POSTGRES_PASSWORD. The `.example` is
# committed as a template.
scripts/.env.local
.worktrees/
.vercel
